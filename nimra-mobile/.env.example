# Google Apps Script remains the source for account/order writes.
EXPO_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec

# Public origin of nimra-web. Product and banner images are loaded only here.
# For a physical device on local Wi-Fi, use the computer's LAN address.
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:3000
